{
  "appId": "pe.serums.desktop",
  "productName": "Sistema Médico SERUMS",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "backend/**/*",
    "package.json",
    "node_modules/**/*"
  ],
  "asar": true,
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*"
  ],
  "win": {
    "target": [
      "nsis"
    ],
    "artifactName": "SERUMS-Setup-${version}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Sistema Médico SERUMS"
  }
}